# Truth Social
TRUTH_BASE_URL=https://truthsocial.com
TRUTH_ACCOUNT_HANDLE=realDonaldTrump
# 可选：如果 lookup 被限流或失败，可手动填 account id
# TRUTH_ACCOUNT_ID=
TRUTH_EXCLUDE_REPLIES=true
TRUTH_EXCLUDE_REBLOGS=true

# Polling
POLL_SECONDS=60
REQUEST_TIMEOUT=20
TIMEZONE=Asia/Shanghai
ALERT_ON_STARTUP=false
STATE_FILE=./outputs/truthsocial_state.json
ENABLE_ARCHIVE_FALLBACK=true
ARCHIVE_RSS_URL=https://trumpstruth.org/feed

# Feishu bot webhook (必填)
FEISHU_WEBHOOK=

# OpenAI analysis (建议填写，不填则仅推送原文)
OPENAI_API_KEY=
ANALYSIS_MODEL=gpt-5-mini
# 分析提供方: minimax / openai / none
ANALYSIS_PROVIDER=minimax

# MiniMax (推荐你当前场景用这个)
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimax.io/v1
MINIMAX_MODEL=MiniMax-M2.7
BACKFILL_MAX_SEND=10

# 可选：指定外部 prompt 文件（优先级高于 ANALYSIS_PROMPT）
# ANALYSIS_PROMPT_FILE=./analysis_prompt.txt
# 可选：直接写一行 prompt
# ANALYSIS_PROMPT=...
